{
  "name": "sentinel-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "TS_NODE_TRANSPILE_ONLY=1 TS_NODE_COMPILER_OPTIONS='{\"module\":\"NodeNext\",\"moduleResolution\":\"NodeNext\"}' node --loader ts-node/esm src/__tests__/run.ts",
    "test:smoke": "tsx src/__tests__/smoke.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@noble/secp256k1": "^2.3.0",
    "@nunncorp/reporting-manifest": "workspace:*",
    "body-parser": "^1.20.2",
    "canonicalize": "^2.0.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.18.2",
    "pg": "^8.13.3",
    "shared-libs": "workspace:*",
    "uuid": "^9.0.0",
    "express-rate-limit": "^8.3.2"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^9.0.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.7.0",
    "typescript": "5.9.3"
  }
}
